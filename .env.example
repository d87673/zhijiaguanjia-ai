# 项目环境变量配置模板
# 复制此文件为 .env 并填入真实值

# 数据库连接（本地开发用 SQLite，生产环境用 PostgreSQL）
DATABASE_URL="postgresql://user:password@localhost:5432/home_service_ai?schema=public"

# NextAuth 密钥（生成方式：openssl rand -base64 32）
NEXTAUTH_SECRET="生成一个随机密钥替换此处"
NEXTAUTH_URL="http://localhost:3000"

# AI 模型接口密钥
DEEPSEEK_API_KEY="你的Deepseek V4 Pro API密钥"
DOUBAO_API_KEY="你的豆包4.0 Ultra API密钥"

# 阿里云服务器
SERVER_IP="阿里云公网IP地址"
SERVER_SSH_KEY_PATH="本地SSH私钥完整路径"

# 支付商户配置
WECHAT_PAY_MCH_ID="微信支付商户号"
WECHAT_PAY_KEY="微信支付API密钥"
ALIPAY_APP_ID="支付宝APPID"
ALIPAY_PRIVATE_KEY="支付宝应用私钥"

# GitHub Actions（用于自动部署）
GITHUB_TOKEN="GitHub个人访问令牌"
